:root {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: #0f172a;
  background: #ffffff;
  line-height: 1.5;
  font-weight: 400;
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  --navy: #0f172a;
  --blue: #1d4ed8;
  --gold: #b68a3d;
  --muted: #f8fafc;
  --border: rgba(15, 23, 42, 0.12);
  --text-soft: #475569;
  --white: #ffffff;
  --shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-width: 320px;
  background: #ffffff;
  color: var(--navy);
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
select,
textarea {
  font: inherit;
}

.app-shell {
  min-height: 100vh;
}

.container {
  width: min(1180px, calc(100% - 2rem));
  margin: 0 auto;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  backdrop-filter: blur(14px);
  background: rgba(255, 255, 255, 0.9);
  border-bottom: 1px solid rgba(15, 23, 42, 0.06);
}

.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  min-height: 82px;
}

.brand-mark {
  display: inline-flex;
  align-items: center;
  gap: 0.85rem;
}

.brand-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, var(--navy), var(--blue));
  color: var(--white);
  font-weight: 700;
  box-shadow: var(--shadow);
}

.brand-mark strong,
.brand-mark span {
  display: block;
}

.brand-mark span {
  color: var(--text-soft);
  font-size: 0.92rem;
}

.site-nav {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  color: var(--text-soft);
  font-size: 0.96rem;
}

.site-nav a:hover,
.site-footer a:hover {
  color: var(--blue);
}

.language-switcher {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  font-size: 0.92rem;
  color: var(--text-soft);
}

.language-switcher select {
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 0.6rem 0.9rem;
  background: #ffffff;
}

.hero-section {
  position: relative;
  overflow: hidden;
  color: var(--white);
  background:
    linear-gradient(115deg, rgba(15, 23, 42, 0.94), rgba(15, 23, 42, 0.76)),
    radial-gradient(circle at top left, rgba(59, 130, 246, 0.42), transparent 38%),
    radial-gradient(circle at bottom right, rgba(182, 138, 61, 0.22), transparent 30%),
    url('/world-grid.svg') center/cover no-repeat;
}

.hero-section::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(255,255,255,0) 70%, rgba(255,255,255,0.03));
}

.hero-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
  gap: 2rem;
  align-items: center;
  padding: 5.5rem 0 5rem;
}

.hero-tag,
.eyebrow {
  display: inline-block;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--gold);
}

.eyebrow.light {
  color: rgba(255, 255, 255, 0.78);
}

.hero-section h1,
.section-heading h2,
.market-band h2 {
  margin: 0.8rem 0 0;
  line-height: 1.05;
  letter-spacing: -0.03em;
}

.hero-section h1 {
  max-width: 12ch;
  font-size: clamp(2.8rem, 6vw, 5.4rem);
}

.hero-copy,
.body-copy,
.body-intro,
.info-card p,
.office-card,
.highlight-card li,
.pill-card {
  color: rgba(255, 255, 255, 0.82);
}

.hero-copy {
  max-width: 680px;
  margin-top: 1.4rem;
  font-size: 1.12rem;
  line-height: 1.9;
}

.hero-actions,
.form-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-top: 2rem;
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.95rem 1.35rem;
  border-radius: 999px;
  border: 1px solid transparent;
  transition: transform 0.2s ease, opacity 0.2s ease, background 0.2s ease;
  cursor: pointer;
}

.button:hover {
  transform: translateY(-1px);
}

.button-primary {
  background: #ffffff;
  color: var(--navy);
  font-weight: 700;
}

.button-secondary {
  border-color: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  background: transparent;
}

.stats-grid {
  margin-top: 2.2rem;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
}

.stat-card,
.highlight-card,
.info-card,
.market-band,
.pill-card,
.office-card,
.contact-form {
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: var(--shadow);
}

.stat-card {
  padding: 1.15rem;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.08);
}

.stat-card span {
  display: block;
  color: rgba(255, 255, 255, 0.72);
  font-size: 0.88rem;
}

.stat-card strong {
  display: block;
  margin-top: 0.5rem;
  font-size: 1rem;
}

.highlight-card {
  border-radius: 32px;
  padding: 2rem;
  background: rgba(255, 255, 255, 0.08);
}

.highlight-card ul {
  margin: 1.2rem 0 0;
  padding: 0;
  list-style: none;
}

.highlight-card li {
  display: flex;
  gap: 0.8rem;
  margin-bottom: 1rem;
  line-height: 1.7;
}

.highlight-card li::before {
  content: '';
  width: 10px;
  height: 10px;
  margin-top: 0.55rem;
  flex: 0 0 auto;
  border-radius: 999px;
  background: var(--white);
}

.content-section {
  padding: 5.5rem 0;
}

.muted-section {
  background: var(--muted);
}

.dark-section {
  background: var(--navy);
  color: var(--white);
}

.two-column {
  display: grid;
  grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.1fr);
  gap: 2rem;
  align-items: start;
}

.wide-gap {
  gap: 3rem;
}

.section-heading h2,
.market-band h2 {
  font-size: clamp(2rem, 4vw, 3.2rem);
}

.body-copy,
.body-intro {
  color: var(--text-soft);
  font-size: 1.05rem;
  line-height: 1.95;
}

.body-copy p,
.body-intro {
  margin: 0 0 1rem;
}

.card-grid {
  display: grid;
  gap: 1.35rem;
  margin-top: 2.2rem;
}

.four-col {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.info-card {
  border-radius: 28px;
  padding: 1.6rem;
  background: #ffffff;
  border-color: rgba(15, 23, 42, 0.08);
}

.info-card h3 {
  margin: 0;
  font-size: 1.1rem;
}

.info-card p {
  margin: 0.9rem 0 0;
  color: var(--text-soft);
  line-height: 1.8;
}

.market-band {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 1.5rem;
  border-radius: 34px;
  padding: 2rem;
  background: #ffffff;
  border-color: rgba(15, 23, 42, 0.08);
}

.market-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  align-items: center;
  justify-content: flex-end;
}

.market-tags span {
  border: 1px solid rgba(15, 23, 42, 0.1);
  border-radius: 999px;
  padding: 0.7rem 1rem;
  color: var(--text-soft);
  background: #ffffff;
}

.dark-section .eyebrow,
.dark-section .section-heading h2 {
  color: var(--white);
}

.pill-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

.pill-card {
  border-radius: 24px;
  padding: 1.1rem 1.2rem;
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.86);
}

.contact-grid {
  display: grid;
  grid-template-columns: minmax(280px, 0.85fr) minmax(0, 1.15fr);
  gap: 2rem;
}

.office-card {
  margin-top: 1.8rem;
  border-radius: 28px;
  padding: 1.4rem;
  background: var(--muted);
  border-color: rgba(15, 23, 42, 0.08);
  color: var(--text-soft);
}

.office-card span,
.office-card strong {
  display: block;
}

.office-card span {
  font-size: 0.88rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: #64748b;
  margin-bottom: 0.7rem;
}

.contact-form {
  border-radius: 34px;
  padding: 1.6rem;
  background: #ffffff;
  border-color: rgba(15, 23, 42, 0.08);
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

.contact-form input,
.contact-form textarea {
  width: 100%;
  border: 1px solid rgba(15, 23, 42, 0.12);
  border-radius: 18px;
  padding: 0.95rem 1rem;
  color: var(--navy);
  background: #ffffff;
}

.contact-form textarea {
  resize: vertical;
}

.full-width {
  grid-column: 1 / -1;
}

.contact-form .button-primary {
  background: var(--navy);
  color: #ffffff;
}

.contact-form .button-secondary {
  color: var(--navy);
  border-color: rgba(15, 23, 42, 0.16);
}

.site-footer {
  border-top: 1px solid rgba(15, 23, 42, 0.08);
  background: #ffffff;
}

.footer-row {
  min-height: 84px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  color: var(--text-soft);
}

.rtl .language-switcher,
.rtl .nav-row,
.rtl .footer-row {
  direction: rtl;
}

@media (max-width: 1080px) {
  .hero-grid,
  .two-column,
  .contact-grid,
  .market-band {
    grid-template-columns: 1fr;
  }

  .four-col {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .market-tags {
    justify-content: flex-start;
  }
}

@media (max-width: 820px) {
  .nav-row {
    min-height: auto;
    padding: 1rem 0;
    flex-wrap: wrap;
  }

  .site-nav {
    order: 3;
    width: 100%;
    justify-content: space-between;
    overflow-x: auto;
    padding-bottom: 0.2rem;
  }

  .stats-grid,
  .pill-grid,
  .form-grid,
  .four-col {
    grid-template-columns: 1fr;
  }

  .hero-section h1 {
    max-width: none;
  }
}

@media (max-width: 560px) {
  .container {
    width: min(100% - 1.2rem, 1180px);
  }

  .content-section,
  .hero-grid {
    padding-top: 4.2rem;
    padding-bottom: 4.2rem;
  }

  .highlight-card,
  .contact-form,
  .info-card,
  .market-band,
  .office-card {
    border-radius: 24px;
  }

  .footer-row {
    min-height: auto;
    padding: 1rem 0 1.4rem;
    flex-direction: column;
    align-items: flex-start;
  }
}
